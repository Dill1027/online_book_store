{
  "name": "online-book-store-backend",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "book-service",
    "customer-service",
    "cart-service",
    "order-service",
    "api-gateway"
  ],
  "scripts": {
    "install:all": "npm install --workspaces",
    "start": "concurrently -k -n BOOK,CUSTOMER,CART,ORDER,GATEWAY -c cyan,green,magenta,yellow,blue \"npm run start:book\" \"npm run start:customer\" \"npm run start:cart\" \"npm run start:order\" \"npm run start:gateway\"",
    "start:book": "npm --workspace book-service run start",
    "start:customer": "npm --workspace customer-service run start",
    "start:cart": "npm --workspace cart-service run start",
    "start:order": "npm --workspace order-service run start",
    "start:gateway": "npm --workspace api-gateway run start"
  },
  "devDependencies": {
    "concurrently": "^7.6.0"
  }
}
